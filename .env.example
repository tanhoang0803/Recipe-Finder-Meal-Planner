# ─────────────────────────────────────────────────────────────
# Recipe Finder & Meal Planner — Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your actual keys.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# Spoonacular API (https://spoonacular.com/food-api)
# Free tier: 150 points/day
REACT_APP_SPOONACULAR_API_KEY=your_spoonacular_api_key_here

# Firebase — get these from Firebase Console > Project Settings > Your apps
REACT_APP_FIREBASE_API_KEY=your_firebase_api_key_here
REACT_APP_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your_project_id_here
REACT_APP_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
REACT_APP_FIREBASE_APP_ID=your_firebase_app_id_here

# OpenAI API (https://platform.openai.com/api-keys)
# Optional — only required for AI suggestion features
# Recommended model: gpt-4o-mini (low cost, fast)
REACT_APP_OPENAI_API_KEY=your_openai_api_key_here

# Google Calendar API (optional — for syncing meal plans to Google Calendar)
REACT_APP_GOOGLE_CLIENT_ID=your_google_client_id_here
REACT_APP_GOOGLE_API_KEY=your_google_api_key_here
