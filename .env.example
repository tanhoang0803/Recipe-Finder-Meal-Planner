# ─────────────────────────────────────────────────────────────
# Recipe Finder & Meal Planner — Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your actual keys.
# NEVER commit .env to version control.
# Vite requires the VITE_ prefix — not REACT_APP_.
# ─────────────────────────────────────────────────────────────

# Spoonacular API (https://spoonacular.com/food-api)
VITE_SPOONACULAR_API_KEY=your_spoonacular_api_key_here

# Firebase — Firebase Console > Project Settings > Your apps
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id_here
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
VITE_FIREBASE_APP_ID=your_firebase_app_id_here

# OpenAI API — optional, required only for AI suggestion features
VITE_OPENAI_API_KEY=your_openai_api_key_here
